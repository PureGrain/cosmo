# ─── Required ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── CORS ───────────────────────────────────────────────────────────────────
# Origin URL for your frontend (no trailing slash)
ALLOWED_ORIGIN=http://localhost:8080

# ─── Model ──────────────────────────────────────────────────────────────────
# Override the default Claude model (default: claude-sonnet-4-20250514)
# MODEL=claude-sonnet-4-20250514

# ─── Admin ──────────────────────────────────────────────────────────────────
# Secret key for /admin/stats endpoint (optional — stats disabled if not set)
# ADMIN_KEY=your-secret-admin-key

# ─── Cloudflare Turnstile (optional) ────────────────────────────────────────
# Get keys from: https://dash.cloudflare.com → Turnstile
# If not set, bot verification is skipped entirely
# TURNSTILE_SECRET=0x4AAAA-your-turnstile-secret-here

# ─── Discord Webhook (optional) ─────────────────────────────────────────────
# Get URL from: Discord → Server Settings → Integrations → Webhooks
# If not set, Discord notifications are skipped
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/your-webhook-url

# ─── Mailgun (optional) ─────────────────────────────────────────────────────
# Required for contact form email replies and chat handoff
# If not set, contact form logs to Discord only (no email reply)
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=mg.yourdomain.com

# ─── Email ──────────────────────────────────────────────────────────────────
# Your email address (for receiving contact form messages via Discord)
# Also used as the reply-to for Mailgun emails
# OWNER_EMAIL=you@example.com

# ─── Rate Limits (optional) ─────────────────────────────────────────────────
# These have sensible defaults — only override if needed
# DAILY_CONV_LIMIT=5         # Max conversations per IP per day (default: 5)
# DAILY_SPEND_LIMIT=1.00     # Max API spend in USD per day (default: $1.00)
# PORT=3001                   # API server port (default: 3001)
